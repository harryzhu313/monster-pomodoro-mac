{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tomato Monster",
  "version": "0.1.0",
  "identifier": "com.tomatomonster.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "panel",
        "url": "panel/panel.html",
        "title": "Tomato Monster",
        "width": 300,
        "height": 420,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": ["icons/icon.png"]
  }
}
